{
  "name": "casper-agentic-rwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agentic RWA risk intelligence marketplace with x402-style payments, MCP tool discovery, and Casper audit receipts.",
  "scripts": {
    "start": "node src/server.mjs",
    "test": "node --test",
    "keygen:casper": "node scripts/generate-casper-key.mjs",
    "prepare:testnet": "node scripts/prepare-testnet-key.mjs",
    "check:testnet": "node scripts/check-testnet-readiness.mjs",
    "preflight:testnet": "node scripts/preflight-testnet-anchor.mjs",
    "preflight:x402": "node scripts/preflight-x402-settlement.mjs",
    "verify:preflight": "node scripts/verify-testnet-preflight.mjs",
    "verify:x402-preflight": "node scripts/verify-x402-settlement-preflight.mjs",
    "verify:evidence": "node scripts/verify-evidence.mjs",
    "judge:proof": "node scripts/generate-judge-proof-pack.mjs",
    "export:buidl": "node scripts/export-buidl-submission.mjs",
    "export:submission": "node scripts/export-submission-pack.mjs",
    "seal:submission": "node scripts/seal-final-submission.mjs",
    "audit:submission": "node scripts/audit-submission.mjs",
    "check:public-demo": "node scripts/check-public-demo-readiness.mjs",
    "check:ci": "node scripts/check-ci-readiness.mjs",
    "video:walkthrough": "node scripts/render-walkthrough-video.mjs",
    "scenario:matrix": "node scripts/generate-scenario-matrix.mjs",
    "proof:publish": "node scripts/publish-proof-room.mjs && node scripts/generate-proof-manifest.mjs",
    "proof:manifest": "node scripts/generate-proof-manifest.mjs",
    "fund:testnet": "node scripts/prepare-highest-prize-unlock.mjs --open-guide --open-faucet --copy-public-key",
    "wait:testnet": "node scripts/wait-testnet-funding.mjs",
    "unlock:highest-prize": "node scripts/prepare-highest-prize-unlock.mjs",
    "anchor:testnet": "node scripts/run-real-anchor.mjs",
    "finalize:testnet": "node scripts/finalize-testnet-evidence.mjs",
    "check:deploy": "node scripts/check-casper-deploy.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "casper-js-sdk": "5.0.12"
  }
}
